# Lần ĐẦU (một lần): cp scripts/jenkins-ci.env.example scripts/jenkins-ci.env → sửa token.
# Sau reboot: KHÔNG cp lại — dùng bash scripts/jenkins-apply-ci-secrets.sh
#
# KHÔNG dùng terraform output eso_access_key_id / eso_secret_access_key — đó là AWS IAM cho ESO.

export DOCKERHUB_USER=minhtri1612
export DOCKERHUB_TOKEN=replace-with-docker-hub-access-token

export GITHUB_USER=minhtri1612
export GITHUB_PAT=replace-with-github-pat
